# Copy this file to .env before running the app:  cp .env.example .env
# SQLite database file, created inside prisma/ on first migrate.
# To use Postgres later, replace with a postgres:// connection string
# and change `provider` in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# Only needed if you open the app through a proxy/tunnel/preview URL and get
# "Invalid Server Actions request" on form submits. (GitHub Codespaces is
# detected automatically — no need to set this there.) Set it to that URL's host —
# the server log prints it as the `origin` value in the error message.
# Restart `npm run dev` after changing it (for production, rebuild too).
# ALLOWED_ORIGINS="3000-yourspace.preview.example.com"
